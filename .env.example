# AI
GEMINI_API_KEY=
GROQ_API_KEY=

# Semantic note retrieval (Gemini embeddings). Default off — set to true after building the index.
ENABLE_GEMINI_NOTE_RETRIEVAL=false

# Firebase Admin (server-side — required for notes storage)
# Local dev: point to the downloaded service account JSON in the project root
FIREBASE_SERVICE_ACCOUNT_PATH=scheduler-110e4-firebase-adminsdk-za56l-5118971862.json

# Production (Vercel): do NOT paste raw JSON (newlines break env vars). Use either:
#   npm run firebase:env   → prints Vercel-safe values from your local JSON file
#
# Option A — three vars:
# FIREBASE_PROJECT_ID=scheduler-110e4
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-...@scheduler-110e4.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n
#
# Option B — one var (base64, no newlines):
# FIREBASE_SERVICE_ACCOUNT_BASE64=

# Optional client Firebase config (browser/analytics only — NOT used for server storage)
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=scheduler-110e4
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=